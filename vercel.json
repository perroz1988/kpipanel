{
  "rewrites": [
    { "source": "/rs-italia", "destination": "/dashboard.html" },
    { "source": "/optimedia", "destination": "/optimedia.html" },
    { "source": "/upload", "destination": "/upload.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/", "destination": "/login.html" }
  ],
  "functions": {
    "api/process.py": { "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/dashboard.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/optimedia.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/upload.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/rs-italia-post-images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    }
  ]
}
